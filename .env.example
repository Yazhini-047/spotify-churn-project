# Environment Configuration Template
# Copy to .env and update with your values

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================

# Environment: development, staging, production
ENVIRONMENT=development

# API Documentation
API_TITLE="Spotify Churn Prediction Backend"
API_VERSION=1.0.0
API_DESCRIPTION="Production REST API for churn prediction, explanation, and playbook execution"

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# SQLite (Development)
DATABASE_URL=sqlite:///./chatbot.db

# PostgreSQL (Production)
# DATABASE_URL=postgresql://postgres:spotify123@localhost:5432/spotify_churn
# DATABASE_URL=postgresql://spotify_app:secure_password@db.example.com:5432/spotify_churn

# Database options
DATABASE_ECHO=False
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# ============================================================================
# CACHE CONFIGURATION (Optional)
# ============================================================================

# Redis
REDIS_URL=redis://localhost:6379
REDIS_DB=0
REDIS_PASSWORD=

# Cache TTL in seconds
CACHE_TTL=3600

# ============================================================================
# MODEL & DATA PATHS
# ============================================================================

# Trained model from Role 1
MODEL_PATH=./model.pkl
MODEL_VERSION=1.0

# Explainability engine from Role 2
EXPLAINER_PATH=./explainer.pkl
EXPLAINER_TYPE=SHAP

# Playbook definitions from Role 2
PLAYBOOK_PATH=./02_PLAYBOOK_RULESET.json

# Feature names
FEATURE_NAMES_PATH=./feature_names.pkl

# ============================================================================
# API CONFIGURATION
# ============================================================================

# Number of workers
WORKERS=4

# Max request size (bytes)
MAX_REQUEST_SIZE=1048576

# Request timeout (seconds)
REQUEST_TIMEOUT=30

# Batch prediction max size
BATCH_MAX_SIZE=1000

# ============================================================================
# SECURITY
# ============================================================================

# Secret key for JWT (if using authentication)
SECRET_KEY=your-secret-key-change-me-in-production

# JWT algorithm
JWT_ALGORITHM=HS256

# JWT expiration (minutes)
JWT_EXPIRATION=60

# API key (if using simple API key auth)
API_KEY=your-api-key-here

# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ============================================================================
# RATE LIMITING
# ============================================================================

# Requests per minute
RATE_LIMIT_STANDARD=100
RATE_LIMIT_BATCH=10
RATE_LIMIT_CHAT=30

# ============================================================================
# MONITORING & LOGGING
# ============================================================================

# Sentry (error tracking)
SENTRY_DSN=

# Datadog (APM)
DATADOG_ENABLED=False
DATADOG_SERVICE_NAME=spotify-churn-backend

# Prometheus metrics
PROMETHEUS_ENABLED=True

# ============================================================================
# EMAIL CONFIGURATION (For notifications)
# ============================================================================

# SMTP Server
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-app-password

# Email settings
EMAIL_FROM=noreply@spotify-churn.com
EMAIL_SUBJECT_PREFIX=[Spotify Churn]

# ============================================================================
# THIRD-PARTY INTEGRATIONS
# ============================================================================

# Slack webhook for alerts
SLACK_WEBHOOK_URL=

# PagerDuty (incident management)
PAGERDUTY_INTEGRATION_KEY=

# DataDog (monitoring)
DATADOG_API_KEY=

# ============================================================================
# AWS CONFIGURATION (For cloud deployment)
# ============================================================================

# AWS credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# S3 for model storage
S3_BUCKET_NAME=spotify-churn-models
S3_MODEL_PREFIX=models/

# RDS database
RDS_ENDPOINT=

# ============================================================================
# DEVELOPMENT ONLY
# ============================================================================

# Debug mode
DEBUG=False

# Hot reload
RELOAD=True

# SQL query logging
SQL_ECHO=False

# ============================================================================
# NOTES
# ============================================================================

# Production Checklist:
# ☐ Change ENVIRONMENT to "production"
# ☐ Use strong SECRET_KEY (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
# ☐ Configure PostgreSQL DATABASE_URL
# ☐ Set API_KEY and restrict ALLOWED_ORIGINS
# ☐ Configure SMTP for email notifications
# ☐ Set up monitoring (Sentry, DataDog, etc.)
# ☐ Enable SSL/TLS (use reverse proxy like nginx)
# ☐ Enable CORS restrictions
# ☐ Set LOG_LEVEL to WARNING
# ☐ Disable SQL_ECHO and DEBUG

# Local Development Setup:
# 1. Copy this file: cp .env.example .env
# 2. Update values as needed
# 3. Load environment: source .env (Unix) or set command (Windows)
# 4. Start server: uvicorn backend_app:app --reload
